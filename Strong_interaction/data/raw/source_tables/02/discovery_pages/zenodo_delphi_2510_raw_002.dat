+00:00", "recid": "7759827", "revision": 2, "files": [{"id": "2430c159-fcac-4cc3-9ce0-3a0af8e3c53f", "key": "BD_NbS-CoBAs-Tool_Validation-Delphi-2nd-Step.xlsx", "size": 17369, "checksum": "md5:f194cd48c1b5df9ba375ce07fed5b034", "links": {"self": "https://zenodo.org/api/records/7759827/files/BD_NbS-CoBAs-Tool_Validation-Delphi-2nd-Step.xlsx/content"}}, {"id": "c8c8fd67-100a-402a-927e-67a0e79b7e0b", "key": "BD_NbS-CoBAs-Tool_Validation-Delphi-1st-Step.xlsx", "size": 21809, "checksum": "md5:d5ee86018748d47d62b2332159e656a8", "links": {"self": "https://zenodo.org/api/records/7759827/files/BD_NbS-CoBAs-Tool_Validation-Delphi-1st-Step.xlsx/content"}}], "swh": null, "owners": [{"id": "520114"}], "status": "published", "stats": {"downloads": 57, "unique_downloads": 52, "views": 131, "unique_views": 126, "version_downloads": 57, "version_unique_downloads": 52, "version_unique_views": 126, "version_views": 131}, "state": "done", "submitted": true}, {"created": "2020-03-04T06:38:27.655521+00:00", "modified": "2020-03-04T07:20:53.993748+00:00", "id": 3696182, "conceptrecid": "3696181", "doi": "10.5281/zenodo.3696182", "conceptdoi": "10.5281/zenodo.3696181", "doi_url": "https://doi.org/10.5281/zenodo.3696182", "metadata": {"title": "delphi-hub/delphi-webapp: Preliminary version of Delphi web application", "doi": "10.5281/zenodo.3696182", "publication_date": "2020-03-04", "description": "<p><strong>v1.0 of Delphi web application.</strong>\nThis is an initial release, which will subsequently be followed by enhancement to the existing functionalities and also bug fixes.  This version includes features such as :</p>\n<ol>\n<li>Search Page with search functionality</li>\n<li>Search page consists of query box where users can type in the query manually.</li>\n<li>Search page has query creation menu which helps a user to build the query by selecting values for specific parts of the query. </li>\n<li>Tooltips on metrics to give a short description. </li>\n<li>A tabular display of results. </li>\n<li>A link in the results that leads to More Information page. This page gives additional information regarding an artifact. The values of all the defined metrics are displayed for an artifact.</li>\n<li>Input validations</li>\n<li>Error handling </li>\n<li>Adoption to newer versions of the API.</li>\n</ol>", "access_right": "open", "creators": [{"name": "Ben Hermann", "affiliation": "Universit\u00e4t Paderborn"}, {"name": "Jan-Niclas Str\u00fcwer", "affiliation": "Fraunhofer IEM"}, {"name": "johannesduesing", "affiliation": null}, {"name": "Hariharan Ramanathan", "affiliation": null}, {"name": "Abdullah Akber", "affiliation": null}], "related_identifiers": [{"identifier": "https://github.com/delphi-hub/delphi-webapp/tree/v1.0", "relation": "isSupplementTo", "scheme": "url"}], "version": "v1.0", "resource_type": {"title": "Software", "type": "software"}, "license": {"id": "other-open"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "3696181"}}]}}, "title": "delphi-hub/delphi-webapp: Preliminary version of Delphi web application", "links": {"self": "https://zenodo.org/api/records/3696182", "self_html": "https://zenodo.org/records/3696182", "preview_html": "https://zenodo.org/records/3696182?preview=1", "doi": "https://doi.org/10.5281/zenodo.3696182", "self_doi": "https://doi.org/10.5281/zenodo.3696182", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3696182", "reserve_doi": "https://zenodo.org/api/records/3696182/draft/pids/doi", "parent": "https://zenodo.org/api/records/3696181", "parent_html": "https://zenodo.org/records/3696181", "parent_doi": "https://doi.org/10.5281/zenodo.3696181", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3696181", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:3696182/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:3696182/sequence/default", "files": "https://zenodo.org/api/records/3696182/files", "media_files": "https://zenodo.org/api/records/3696182/media-files", "archive": "https://zenodo.org/api/records/3696182/files-archive", "archive_media": "https://zenodo.org/api/records/3696182/media-files-archive", "latest": "https://zenodo.org/api/records/3696182/versions/latest", "latest_html": "https://zenodo.org/records/3696182/latest", "versions": "https://zenodo.org/api/records/3696182/versions", "draft": "https://zenodo.org/api/records/3696182/draft", "access_links": "https://zenodo.org/api/records/3696182/access/links", "access_grants": "https://zenodo.org/api/records/3696182/access/grants", "access_users": "https://zenodo.org/api/records/3696182/access/users", "access_request": "https://zenodo.org/api/records/3696182/access/request", "access": "https://zenodo.org/api/records/3696182/access", "communities": "https://zenodo.org/api/records/3696182/communities", "communities-suggestions": "https://zenodo.org/api/records/3696182/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/3696182/request-deletion", "file_modification": "https://zenodo.org/api/records/3696182/file-modification", "quota_increase": "https://zenodo.org/api/records/3696182/quota-increase", "requests": "https://zenodo.org/api/records/3696182/requests"}, "updated": "2020-03-04T07:20:53.993748+00:00", "recid": "3696182", "revision": 3, "files": [{"id": "d300312b-15d1-4a09-a272-9e745f00dc49", "key": "delphi-hub/delphi-webapp-v1.0.zip", "size": 1040421, "checksum": "md5:0147320a4eedf4ba332ffed127274929", "links": {"self": "https://zenodo.org/api/records/3696182/files/delphi-hub/delphi-webapp-v1.0.zip/content"}}], "swh": null, "owners": [{"id": "30817"}], "status": "published", "stats": {"downloads": 17, "unique_downloads": 17, "views": 74, "unique_views": 73, "version_downloads": 17, "version_unique_downloads": 17, "version_unique_views": 73, "version_views": 74}, "state": "done", "submitted": true}, {"created": "2016-03-10T16:23:28+00:00", "modified": "2024-08-04T04:18:55.583714+00:00", "id": 46158, "conceptrecid": "630055", "doi": "10.5281/zenodo.46158", "conceptdoi": "", "doi_url": "https://doi.org/10.5281/zenodo.46158", "metadata": {"title": "Status Report of the DPHEP Collaboration: A Global Effort for Sustainable Data Preservation in High Energy Physics", "doi": "10.5281/zenodo.46158", "publication_date": "2016-02-17", "description": "<p>Data from High Energy Physics (HEP) experiments are collected with significant financial and human effort and are mostly unique. An inter-experimental study group on HEP data preservation and long-term analysis was convened as a panel of the International Committee for Future Accelerators (ICFA). The group was formed by large collider-based experiments and investigated the technical and organisational aspects of HEP data preservation. An intermediate report was released in November 2009 addressing the general issues of data preservation in HEP and an extended blueprint paper was published in 2012. In July 2014 the DPHEP collaboration was formed as a result of the signature of the Collaboration Agreement by seven large funding agencies (others have since joined or are in the process of acquisition) and in June 2015 the first DPHEP Collaboration Workshop and Collaboration Board meeting took place.</p>\n\n<p><br />\nThis status report of the DPHEP collaboration details the progress during the period 2013 &ndash; 2015 inclusive.</p>", "access_right": "open", "creators": [{"name": "DPHEP Collaboration", "affiliation": null}, {"name": "Amerio, Silvia", "affiliation": "INFN"}, {"name": "Barbera, Roberto", "affiliation": "Univ. of Catania and INFN"}, {"name": "Berghaus, Frank", "affiliation": "CERN"}, {"name": "Blomer, Jakob", "affiliation": "CERN"}, {"name": "Branson, Andrew", "affiliation": "University of the West of England"}, {"name": "Cancio, Germ\u00e1n", "affiliation": "CERN"}, {"name": "Cartaro, Concetta", "affiliation": "SLAC"}, {"name": "Chen, Gang", "affiliation": "IHEP"}, {"name": "Dallmeier-Tiessen, S\u00fcnje", 