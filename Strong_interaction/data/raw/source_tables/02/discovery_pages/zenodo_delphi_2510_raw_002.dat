les", "media_files": "https://zenodo.org/api/records/13266152/media-files", "archive": "https://zenodo.org/api/records/13266152/files-archive", "archive_media": "https://zenodo.org/api/records/13266152/media-files-archive", "latest": "https://zenodo.org/api/records/13266152/versions/latest", "latest_html": "https://zenodo.org/records/13266152/latest", "versions": "https://zenodo.org/api/records/13266152/versions", "draft": "https://zenodo.org/api/records/13266152/draft", "access_links": "https://zenodo.org/api/records/13266152/access/links", "access_grants": "https://zenodo.org/api/records/13266152/access/grants", "access_users": "https://zenodo.org/api/records/13266152/access/users", "access_request": "https://zenodo.org/api/records/13266152/access/request", "access": "https://zenodo.org/api/records/13266152/access", "communities": "https://zenodo.org/api/records/13266152/communities", "communities-suggestions": "https://zenodo.org/api/records/13266152/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/13266152/request-deletion", "file_modification": "https://zenodo.org/api/records/13266152/file-modification", "quota_increase": "https://zenodo.org/api/records/13266152/quota-increase", "requests": "https://zenodo.org/api/records/13266152/requests"}, "updated": "2024-08-08T04:20:39.314281+00:00", "recid": "13266152", "revision": 4, "files": [], "swh": null, "owners": [{"id": "494530"}], "status": "published", "stats": {"downloads": 0, "unique_downloads": 0, "views": 31, "unique_views": 28, "version_downloads": 0, "version_unique_downloads": 0, "version_unique_views": 28, "version_views": 31}, "state": "done", "submitted": true}, {"created": "2024-06-27T17:56:06.332623+00:00", "modified": "2024-06-27T17:56:06.666413+00:00", "id": 12572310, "conceptrecid": "12572309", "doi": "10.5281/zenodo.12572310", "conceptdoi": "10.5281/zenodo.12572309", "doi_url": "https://doi.org/10.5281/zenodo.12572310", "metadata": {"title": "Delphi", "doi": "10.5281/zenodo.12572310", "publication_date": "2024-06-27", "description": "Delphi was the main, institutional oracular site in ancient Greece. On an ancient temple site with purported divinatory practices going as far back at 1600 BCE, it became a formal cult site of Apollo and his oracle in the 8th century BCE. The central religious activity was the Oracle at Delphi, also known as the \"Pythia\" after the primordial, mythical python slain by the god Apollo at the site to claim it for the Greek pantheon. The Pythia was both the high priestess of Apollo and his oracular mouthpiece, uttering authoritative but vague and often frenzied prophecies that made her the object of fascination across the ancient Mediterranean. The Pythia was attended by a formal priesthood in charge of the cult site and its practices. This cult site grew to become a major cultural and pilgrimage center, with extensive structures including temples, a treasury, theater, sanctuary, gymnasium, stadium, hippodrome, and extensive statuary and other offerings.", "access_right": "open", "creators": [{"name": "Paul Robertson", "affiliation": "University of New Hampshire"}], "contributors": [{"name": "Canlas, Gino", "affiliation": "University of British Columbia", "type": "Editor"}], "keywords": ["Religious Group", "Greek Religions", "Hellenistic Religions", "Ancient Mediterranean", "Religious Place", "Monument", "Temple", "Religious Complex", "Temenos", "Shrines", "Greek Cult", "Archaeological monument", "Polytheistic"], "resource_type": {"title": "Journal article", "type": "publication", "subtype": "article"}, "journal": {"title": "The Database of Religious History"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "12572309"}}]}}, "title": "Delphi", "links": {"self": "https://zenodo.org/api/records/12572310", "self_html": "https://zenodo.org/records/12572310", "preview_html": "https://zenodo.org/records/12572310?preview=1", "doi": "https://doi.org/10.5281/zenodo.12572310", "self_doi": "https://doi.org/10.5281/zenodo.12572310", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.12572310", "reserve_doi": "https://zenodo.org/api/records/12572310/draft/pids/doi", "parent": "https://zenodo.org/api/records/12572309", "parent_html": "https://zenodo.org/records/12572309", "parent_doi": "https://doi.org/10.5281/zenodo.12572309", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.12572309", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:12572310/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:12572310/sequence/default", "files": "https://zenodo.org/api/records/12572310/files", "media_files": "https://zenodo.org/api/records/12572310/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E10,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E50,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E100,/0/default.jpg", "250": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E250,/0/default.jpg", "750": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E750,/0/default.jpg", "1200": "https://zenodo.org/api/iiif/record:12572310:Delphi.pdf/full/%5E1200,/0/default.jpg"}, "archive": "https://zenodo.org/api/records/12572310/files-archive", "archive_media": "https://zenodo.org/api/records/12572310/media-files-archive", "latest": "https://zenodo.org/api/records/12572310/versions/latest", "latest_html": "https://zenodo.org/records/12572310/latest", "versions": "https://zenodo.org/api/records/12572310/versions", "draft": "https://zenodo.org/api/records/12572310/draft", "access_links": "https://zenodo.org/api/records/12572310/access/links", "access_grants": "https://zenodo.org/api/records/12572310/access/grants", "access_users": "https://zenodo.org/api/records/12572310/access/users", "access_request": "https://zenodo.org/api/records/12572310/access/request", "access": "https://zenodo.org/api/records/12572310/access", "communities": "https://zenodo.org/api/records/12572310/communities", "communities-suggestions": "https://zenodo.org/api/records/12572310/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/12572310/request-deletion", "file_modification": "https://zenodo.org/api/records/12572310/file-modification", "quota_increase": "https://zenodo.org/api/records/12572310/quota-increase", "requests": "https://zenodo.org/api/records/12572310/requests"}, "updated": "2024-06-27T17:56:06.666413+00:00", "recid": "12572310", "revision": 4, "files": [{"id": "408ccc53-4609-4a03-99e9-1294524cf87d", "key": "Delphi.pdf", "size": 420889, "checksum": "md5:c645e09d6056ed5429b3e9cfb03eef9a", "links": {"self": "https://zenodo.org/api/records/12572310/files/Delphi.pdf/content"}}], "swh": null, "owners": [{"id": "1076843"}], "status": "published", "stats": {"downloads": 25, "unique_downloads": 23, "views": 36, "unique_views": 36, "version_downloads": 25, "version_unique_downloads": 23, "version_unique_views": 36, "version_views": 36}, "state": "done", "submitted": true}, {"created": "2021-07-17T09:14:00.469272+00:00", "modified": "2021-07-17T13:48:15.826696+00:00", "id": 5111434, "conceptrecid": "5111433", "doi": "10.5281/zenodo.5111434", "conceptdoi": "10.5281/zenodo.5111433", "doi_url": "https://doi.org/10.5281/zenodo.5111434", "metadata": {"title": "The Future of Compulsory Schooling: Participant developed scenarios from a Modified Delphi Survey", "doi": "10.5281/zenodo.5111434", "publication_date": "2021-07-17", "description": "<p>This paper describes results from a modified Delphi process that has been informed by research into anticipatory systems to design an approach that is responsive to a future world which is uncertain and in rapid change. We present five scenarios that describe preferred futures for the design of compulsory schooling and addresses the overall, counterfactual, research question, &ldquo;What if compulsory schooling was a 21st century invention?&rdquo; The scenarios have been developed by participants as the last round in the modified Delphi process, utilising a set of statements created in the earlier rounds. This scenario development round describes a novel use of the modified Delphi process in addition to the previous rounds that were used to determine more traditional Delphi results in terms of consensus and dissensus.&nbsp;</p>\n\n<p>The attachments&nbsp;provide an annexure with additional information about the Expert panel as well as&nbsp;a complete list of statements from the modified Delphi process.</p>", "access_right": "open", "creators": [{"name": "McGrath, Jason", "affiliation": "The University of Newcastle", "orcid": "0000-0002-5659-7761"}, {"name": "Fischetti, John", "affiliation": "The University of Newcastle"}], "keywords": ["futures", "compulsory schooling", "modified Delphi", "future models of schooling"], "language": "eng", "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "5111433"}}]}}, "title": "The Future of Compulsory Schooling: Participant developed scenarios from a Modified Delphi Survey", "links": {"self": "https://zenodo.org/api/records/5111434", "self_html": "https://zenodo.org/records/5111434", "preview_html": "https://zenodo.org/records/5111434?preview=1", "doi": "https://doi.org/10.5281/zenodo.5111434", "self_doi": "https://doi.org/10.5281/zenodo.5111434", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.5111434", "reserve_doi": "https://zenodo.org/api/records/5111434/draft/pids/doi", "parent": "https://zenodo.org/api/records/5111433", "parent_html": "https://zenodo.org/records/5111433", "parent_doi": "https://doi.org/10.5281/zenodo.5111433", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.5111433", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:5111434/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:5111434/sequence/default", "files": "https://zenodo.org/api/records/5111434/files", "media_files": "https://zenodo.org/api/records/5111434/media-files", "archive": "https://zenodo.org/api/records/5111434/files-archive", "archive_media": "https://zenodo.org/api/records/5111434/media-files-archive", "latest": "https://zenodo.org/api/records/5111434/versions/latest", "latest_html": "https://zenodo.org/records/5111434/latest", "versions": "https://zenodo.org/api/records/5111434/versions", "draft": "https://zenodo.org/api/records/5111434/draft", "access_links": "https://zenodo.org/api/records/5111434/access/links", "access_grants": "https://zenodo.org/api/records/5111434/access/grants", "access_users": "https://zenodo.org/api/records/5111434/access/users", "access_request": "https://zenodo.org/api/records/5111434/access/request", "access": "https://zenodo.org/api/records/5111434/access", "communities": "https://zenodo.org/api/records/5111434/communities", "communities-suggestions": "https://zenodo.org/api/records/5111434/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/5111434/request-deletion", "file_modification": "https://zenodo.org/api/records/5111434/file-modification", "quota_increase": "https://zenodo.org/api/records/5111434/quota-increase", "requests": "https://zenodo.org/api/records/5111434/requests"}, "updated": "2021-07-17T13:48:15.826696+00:00", "recid": "5111434", "revision": 2, "files": [{"id": "a1028edc-3e63-4a6f-ae36-1d9634e5d9f0", "key": "Paper 3 Scenarios.xlsx", "size": 44721, "checksum": "md5:de40396d65719f0c1be7e8b49a1e2c98", "links": {"self": "https://zenodo.org/api/records/5111434/files/Paper%203%20Scenarios.xlsx/content"}}, {"id": "494ccb29-67f5-4797-8800-e2b97e1fca9d", "key": "Annexure Additional Information about the Expert Panel.docx", "size": 15187, "checksum": "md5:9538b9bca0c5f845790ba124ec1bcb46", "links": {"self": "https://zenodo.org/api/records/5111434/files/Annexure%20Additional%20Information%20about%20the%20Expert%20Panel.docx/content"}}], "swh": null, "owners": [{"id": "131174"}], "status": "published", "stats": {"downloads": 54, "unique_downloads": 52, "views": 246, "unique_views": 238, "version_downloads": 54, "version_unique_downloads": 52, "version_unique_views": 238, "version_views": 246}, "state": "done", "submitted": true}, {"created": "2020-08-05T09:17:55.435354+00:00", "modified": "2024-07-19T17:25:08.300115+00:00", "id": 3972905, "conceptrecid": "3972904", "doi": "10.5281/zenodo.3972905", "conceptdoi": "10.5281/zenodo.3972904", "doi_url": "https://doi.org/10.5281/zenodo.3972905", "metadata": {"title": "D4.7 Role of DELPHI Report", "doi": "10.5281/zenodo.3972905", "publication_date": "2019-10-30", "description": "<p>This report evaluates the role of the Delphi methodology, as used in the public engagement activities of the ClairCity project (Work Package 4) ClairCity project, in air quality and carbon management research. Focusing on ClairCity this report asseses the use of the methodology in citizen-focused research (Citizen Delphi) and makes recommendations for future use of Delphi methodology in similar studies.</p>", "access_right": "open", "creators": [{"name": "Jo Barnes", "affiliation": null}, {"name": "Laura de Vito", "affiliation": null}, {"name": "Laura Fogg-Rogers", "affiliation": null}, {"name": "Corra Boushel", "affiliation": null}], "resource_type": {"title": "Project deliverable", "type": "publication", "subtype": "deliverable"}, "license": {"id": "cc-by-4.0"}, "communities": [{"id": "claircity"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "3972904"}}]}}, "title": "D4.7 Role of DELPHI Report", "links": {"self": "https://zenodo.org/api/records/3972905", "self_html": "https://zenodo.org/records/3972905", "preview_html": "https://zenodo.org/records/3972905?preview=1", "doi": "https://doi.org/10.5281/zenodo.3972905", "self_doi": "https://doi.org/10.5281/zenodo.3972905", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3972905", "reserve_doi": "https://zenodo.org/api/records/3972905/draft/pids/doi", "parent": "https://zenodo.org/api/records/3972904", "parent_html": "https://zenodo.org/records/3972904", "parent_doi": "https://doi.org/10.5281/zenodo.3972904", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3972904", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:3972905/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:3972905/sequence/default", "files": "https://zenodo.org/api/records/3972905/files", "media_files": "https://zenodo.org/api/records/3972905/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E10,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E50,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E100,/0/default.jpg", "250": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E250,/0/default.jpg", "750": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E750,/0/default.jpg", "1200": "https://zenodo.org/api/iiif/record:3972905:D4.7%20Role%20of%20Delphi%20FINAL.pdf/full/%5E1200,/0/default.jpg"}, "archive": "https://zenodo.org/api/records/3972905/files-archive", "archive_media": "https://zenodo.org/api/records/3972905/media-files-archive", "latest": "https://zenodo.org/api/records/3972905/versions/latest", "latest_html": "https://zenodo.org/records/3972905/latest", "versions": "https://zenodo.org/api/records/3972905/versions", "draft": "https://zenodo.org/api/records/3972905/draft", "access_links": "https://zenodo.org/api/records/3972905/access/links", "access_grants": "https://zenodo.org/api/records/3972905/access/grants", "access_users": "https://zenodo.org/api/records/3972905/access/users", "access_request": "https://zenodo.org/api/records/3972905/access/request", "access": "https://zenodo.org/api/records/3972905/access", "communities": "https://zenodo.org/api/records/3972905/communities", "communities-suggestions": "https://zenodo.org/api/records/3972905/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/3972905/request-deletion", "file_modification": "https://zenodo.org/api/records/3972905/file-modification", "quota_increase": "https://zenodo.org/api/records/3972905/quota-increase", "requests": "https://zenodo.org/api/records/3972905/requests"}, "updated": "2024-07-19T17:25:08.300115+00:00", "recid": "3972905", "revision": 7, "files": [{"id": "cd912096-3177-4745-b9dd-2b3a35072258", "key": "D4.7 Role of Delphi FINAL.pdf", "size": 762650, "checksum": "md5:497378e55aafd8166a0ebcfea81216c2", "links": {"self": "https://zenodo.org/api/records/3972905/files/D4.7%20Role%20of%20Delphi%20FINAL.pdf/content"}}], "swh": null, "owners": [{"id": "113402"}], "status": "published", "stats": {"downloads": 147, "unique_downloads": 123, "views": 295, "unique_views": 272, "version_downloads": 146, "version_unique_downloads": 122, "version_unique_views": 269, "version_views": 292}, "state": "done", "submitted": true}, {"created": "2023-10-06T08:25:52.597555+00:00", "modified": "2023-10-07T02:27:02.862987+00:00", "id": 8402507, "conceptrecid": "8402506", "doi": "10.5281/zenodo.8402507", "conceptdoi": "10.5281/zenodo.8402506", "doi_url": "https://doi.org/10.5281/zenodo.8402507", "metadata": {"title": "Real-Time Delphi data: How to identify and interpret weak signals of change in the forest bioeconomy", "doi": "10.5281/zenodo.8402507", "publication_date": "2023-10-06", "description": "<p>Data from: Mauno, T., Catelo, F., Bengston, D.N., Pyk&auml;l&auml;inen, J. &amp; Hujala, T. 2023. How to identify and interpret weak signals of change in the forest bioeconomy. Forest Policy and Economics. <a href=\"https://doi.org/10.1016/j.forpol.2023.103075?_gl=1*a2eeob*_ga*NDE0MDgzOTYwLjE2OTY0ODY2MTY.*_ga_NY8L5SJPMB*MTY5NjQ5NDIxNi4yLjEuMTY5NjUwMTI0Mi4wLjAuMA..\">https://doi.org/10.1016/j.forpol.2023.103075</a></p>\n\n<p>This exploratory study sought to understand how to identify and interpret weak signals of change that may have an impact on the forest bioeconomy. An international panel of experts in the forest bioeconomy and in foresight provided their views through a two-stage Real-Time Delphi method which utilized the multiple rounds of traditional Delphi and the instantaneous feedback of the Real-Time Delphi method.</p>\n\n<p>The Real-Time Delphi exercise was conducted in two stages through the eDelphi software (edelphi.org); the first stage was focused on <em>Changes</em> and the second on <em>Weak Signals</em>. For the Real-Time Delphi exercise, two expert matrices (forest bioeconomy matrix and&nbsp;futures &amp; foresight matrix) were prepared with the aim of obtaining diverse expertise to participate in the study.</p>\n\n<p>The first stage was conducted during a 10-day period in early September 2022 (Sep 5, 2022 &ndash; Sep 14, 2022). The second stage was also conducted&nbsp;during a 10-day period later in September 2022 (Sep 21, 2022 &ndash; Sep 30, 2022). A total of 11 (6 forest bioeconomy experts and 5 futures research and foresight specialists) participated in both eDelphi stages.</p>\n\n<p>This dataset includes: (i) completed Real-Time Delphi stages (including anonymized answers and discussions of 11 participants) (ii) questions for both Real-Time Delphi stages, and (iii) anonymized expert matrices (forest bioeconomy matrix and&nbsp;futures &amp; foresight matrix)</p>\n\n<p>For more information, please contact the corresponding author (data controller): Tuomas Mauno (University of Eastern Finland), tuomas.mauno@uef.fi</p>", "access_right": "open", "creators": [{"name": "Mauno, Tuomas", "affiliation": "University of Eastern Finland", "orcid": "0000-0001-6133-1426"}, {"name": "Catelo, Fellice", "affiliation": "University of Eastern Finland", "orcid": "0009-0006-1581-1019"}, {"name": "Bengston, David N.", "affiliation": "USDA Forest Service", "orcid": "0000-0002-7358-1059"}, {"name": "Pyk\u00e4l\u00e4inen, Jouni", "affiliation": "University of Eastern Finland", "orcid": "0000-0003-3427-9954"}, {"name": "Hujala, Teppo", "affiliation": "University of Eastern Finland", "orcid": "0000-0002-7905-7602"}], "keywords": ["Forest bioeconomy", "Foresight", "Future changes", "Real-Time Delphi", "Weak signals"], "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "8402506"}}]}, "notes": "The data collection was funded by the Saastamoinen Foundation and the Niemi Foundation supported the completion of the study."}, "title": "Real-Time Delphi data: How to identify and interpret weak signals of change in the forest bioeconomy", "links": {"self": "https://zenodo.org/api/records/8402507", "self_html": "https://zenodo.org/records/8402507", "preview_html": "https://zenodo.org/records/8402507?preview=1", "doi": "https://doi.org/10.5281/zenodo.8402507", "self_doi": "https://doi.org/10.5281/zenodo.8402507", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.8402507", "reserve_doi": "https://zenodo.org/api/records/8402507/draft/pids/doi", "parent": "https://zenodo.org/api/records/8402506", "parent_html": "https://zenodo.org/records/8402506", "parent_doi": "https://doi.org/10.5281/zenodo.8402506", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.8402506", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:8402507/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:8402507/sequence/default", "files": "https://zenodo.org/api/records/8402507/files", "media_files": "https://zenodo.org/api/records/8402507/media-files", "archive": "https://zenodo.org/api/records/8402507/files-archive", "archive_media": "https://zenodo.org/api/records/8402507/media-files-archive", "latest": "https://zenodo.org/api/records/8402507/versions/latest", "latest_html": "https://zenodo.org/records/8402507/latest", "versions": "https://zenodo.org/api/records/8402507/versions", "draft": "https://zenodo.org/api/records/8402507/draft", "access_links": "https://zenodo.org/api/records/8402507/access/links", "access_grants": "https://zenodo.org/api/records/8402507/access/grants", "access_users": "https://zenodo.org/api/records/8402507/access/users", "access_request": "https://zenodo.org/api/records/8402507/access/request", "access": "https://zenodo.org/api/records/8402507/access", "communities": "https://zenodo.org/api/records/8402507/communities", "communities-suggestions": "https://zenodo.org/api/records/8402507/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/8402507/request-deletion", "file_modification": "https://zenodo.org/api/records/8402507/file-modification", "quota_increase": "https://zenodo.org/api/records/8402507/quota-increase", "requests": "https://zenodo.org/api/records/8402507/requests"}, "updated": "2023-10-07T02:27:02.862987+00:00", "recid": "8402507", "revision": 2, "files": [{"id": "beac9d4f-1a2b-49f8-8e38-4d32ab5e0747", "key": "How_to_Identify_and_Interpret_Weak_Signals_of_Change_in_the_Forest_Bioeconomy_2023_(Real-Time_Delphi_data).zip", "size": 172592, "checksum": "md5:d0ad7b85423385555c83c951a95aebdd", "links": {"self": "https://zenodo.org/api/records/8402507/files/How_to_Identify_and_Interpret_Weak_Signals_of_Change_in_the_Forest_Bioeconomy_2023_(Real-Time_Delphi_data).zip/content"}}], "swh": null, "owners": [{"id": "221400"}], "status": "published", "stats": {"downloads": 26, "unique_downloads": 26, "views": 625, "unique_views": 587, "version_downloads": 26, "version_unique_downloads": 26, "version_unique_views": 559, "version_views": 582}, "state": "done", "submitted": true}, {"created": "2020-12-29T10:53:17.730604+00:00", "modified": "2024-07-19T11:25:14.166092+00:00", "id": 4399143, "conceptrecid": "4399142", "doi": "10.22163/fteval.2020.469", "doi_url": "https://doi.org/10.22163/fteval.2020.469", "metadata": {"title": "Using the Delphi Method in evaluations - incorporating a future oriented perspective in evaluations", "doi": "10.22163/fteval.2020.469", "publication_date": "2020-03-26", "description": "<p>This article discusses the scope of use of the Delphi method in evaluations. It suggests that the Delphi method is a promising approach for validating the evidence gathered by incorporating a forward-looking perspective in the drawing of conclusions and in elaborating recommendations by making use of expert knowledge from different domains. Thereby, the Delphi method also facilitates information and engagement of relevant stakeholder communities in an ongoing evaluation process. Based upon the application of the method in the Evaluation of the Support Structures for Horizon 2020, EUREKA, COSME, EEN and ERA in Austria, the article demonstrates how the application of the Delphi method allows to analyse the degree of fit of an existing service portfolio against changing framework conditions and expected developments in the future.</p>", "access_right": "open", "creators": [{"name": "Dinges, Michael", "affiliation": "AIT Austrian Institute of Technology GmbH"}, {"name": "Wang, Anna", "affiliation": "AIT Austrian Institute of Technology GmbH"}, {"name": "Schuch, Klaus", "affiliation": "Centre for Social Innovation"}], "keywords": ["Institutional Change & Policy Instruments", "stakeholder communities", "support structures", "Horizon 2020"], "language": "eng", "resource_type": {"title": "Journal article", "type": "publication", "subtype": "article"}, "journal": {"pages": "44-50", "title": "fteval Journal for Research and Technology Policy Evaluation", "volume": "50"}, "license": {"id": "cc-by-4.0"}, "communities": [{"id": "ait-isp"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "4399142"}}]}}, "title": "Using the Delphi Method in evaluations - incorporating a future oriented perspective in evaluations", "links": {"self": "https://zenodo.org/api/records/4399143", "self_html": "https://zenodo.org/records/4399143", "preview_html": "https://zenodo.org/records/4399143?preview=1", "doi": "https://doi.org/10.22163/fteval.2020.469", "self_doi": "https://doi.org/10.22163/fteval.2020.469", "self_doi_html": "https://zenodo.org/doi/10.22163/fteval.2020.469", "reserve_doi": "https://zenodo.org/api/records/4399143/draft/pids/doi", "parent": "https://zenodo.org/api/records/4399142", "parent_html": "https://zenodo.org/records/4399142", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:4399143/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:4399143/sequence/default", "files": "https://zenodo.org/api/records/4399143/files", "media_files": "https://zenodo.org/api/records/4399143/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E10,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E50,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E100,/0/default.jpg", "250": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E250,/0/default.jpg", "750": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E750,/0/default.jpg", "1200": "https://zenodo.org/api/iiif/record:4399143:Journal_50_10.22163-fteval.2020.469.pdf/full/%5E1200,/0/default.jpg"}, "archive": "https://zenodo.org/api/records/4399143/files-archive", "archive_media": "https://zenodo.org/api/records/4399143/media-files-archive", "latest": "https://zenodo.org/api/records/4399143/versions/latest", "latest_html": "https://zenodo.org/records/4399143/latest", "versions": "https://zenodo.org/api/records/4399143/versions", "draft": "https://zenodo.org/api/records/4399143/draft", "access_links": "https://zenodo.org/api/records/4399143/access/links", "access_grants": "https://zenodo.org/api/records/4399143/access/grants", "access_users": "https://zenodo.org/api/records/4399143/access/users", "access_request": "https://zenodo.org/api/records/4399143/access/request", "access": "https://zenodo.org/api/records/4399143/access", "communities": "https://zenodo.org/api/records/4399143/communities", "communities-suggestions": "https://zenodo.org/api/records/4399143/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/4399143/request-deletion", "file_modification": "https://zenodo.org/api/records/4399143/file-modification", "quota_increase": "https://zenodo.org/api/records/4399143/quota-increase", "requests": "https://zenodo.org/api/records/4399143/requests"}, "updated": "2024-07-19T11:25:14.166092+00:00", "recid": "4399143", "revision": 10, "files": [{"id": "d4ad4edd-e7f4-4396-83c6-859561d5440e", "key": "Journal_50_10.22163-fteval.2020.469.pdf", "size": 613041, "checksum": "md5:c81d38cc90b49d3118bf47e2b9d3d767", "links": {"self": "https://zenodo.org/api/records/4399143/files/Journal_50_10.22163-fteval.2020.469.pdf/content"}}], "swh": null, "owners": [{"id": "144954"}], "status": "published", "stats": {"downloads": 104, "unique_downloads": 103, "views": 85, "unique_views": 79, "version_downloads": 104, "version_unique_downloads": 103, "version_unique_views": 79, "version_views": 85}, "state": "done", "submitted": true}, {"created": "2020-12-17T16:08:51.914690+00:00", "modified": "2024-07-19T12:05:58.907245+00:00", "id": 4338856, "conceptrecid": "4338855", "doi": "10.1016/j.mex.2020.101179", "doi_url": "https://doi.org/10.1016/j.mex.2020.101179", "metadata": {"title": "Lessons Learned from a Two-Round Delphi-based Scenario Study", "doi": "10.1016/j.mex.2020.101179", "publication_date": "2020-12-16", "description": "<p>The Delphi technique is a suitable methodology for structuring group communication to answer current and prospective research questions within several rounds. The method is used in many disciplines and characterized by anonymity, iteration, controlled feedback, and statistical &ldquo;group response&rdquo;(Rowe &amp; Wright, 2001). This technical paper presents practical details and lessons learned from a two-round Delphi-based scenario study in which projections (Delphi statements, questions or hypotheses) were developed with findings from expert interviews and an expert workshop. This Delphi study provides answers to future-related questions for which other research methods are inappropriate. This is depicted as a five-step process, making it easy to follow and replicable, for example to help first-time Delphi-method researchers. In doing so, the authors aim to provide the community with valuable technical insights and guidance for studies applying the Delphi technique both to prospective questions and in other research settings.</p>\n\n<p>- Conducting a Delphi study can be a slow process with respect to receiving feedback from the panelists. Planning an appropriate period for distributing the questionnaire may produce a higher return rate. A sufficient time buffer should be incorporated into project planning.</p>\n\n<p>- Projections that create dissent among the panelists may provide valuable results.</p>\n\n<p>- Data analytics, software programs and online social networks can support researchers, save time and resources, and provide further insights in the process of conducting a Delphi study.</p>", "access_right": "open", "creators": [{"name": "Schmalz, Ulrike", "affiliation": "Bauhaus Luftfahrt e.V.", "orcid": "0000-0003-2935-6281"}, {"name": "Spinler, Stefan", "affiliation": "WHU \u2013Otto-Beisheim School of Management"}, {"name": "Ringbeck, J\u00fcrgen", "affiliation": "WHU \u2013Otto-Beisheim School of Management"}], "keywords": ["Consensus", "Delphi method", "Expert knowledge", "Foresight", "Forecasting", "Hierarchical cluster analysis", "Judgement", "Scenario development"], "related_identifiers": [{"identifier": "10.1016/j.mex.2020.101179", "relation": "isIdenticalTo", "resource_type": "publication-article", "scheme": "doi"}], "version": "v1", "language": "eng", "resource_type": {"title": "Journal article", "type": "publication", "subtype": "article"}, "journal": {"pages": "101179", "title": "MethodsX", "volume": "8 (2021)"}, "license": {"id": "cc-by-4.0"}, "grants": [{"code": "769606", "internal_id": "10.13039/501100000780::769606", "funder": {"name": "European Commission", "doi": "10.13039/501100000780", "acronym": "EC"}, "title": "Coordination and support Action for Mobility in Europe: Research and Assessment", "acronym": "CAMERA", "program": "H2020-EU.3.4.", "url": "https://cordis.europa.eu/projects/769606"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "4338855"}}]}}, "title": "Lessons Learned from a Two-Round Delphi-based Scenario Study", "links": {"self": "https://zenodo.org/api/records/4338856", "self_html": "https://zenodo.org/records/4338856", "preview_html": "https://zenodo.org/records/4338856?preview=1", "doi": "https://doi.org/10.1016/j.mex.2020.101179", "self_doi": "https://doi.org/10.1016/j.mex.2020.101179", "self_doi_html": "https://zenodo.org/doi/10.1016/j.mex.2020.101179", "reserve_doi": "https://zenodo.org/api/records/4338856/draft/pids/doi", "parent": "https://zenodo.org/api/records/4338855", "parent_html": "https://zenodo.org/records/4338855", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:4338856/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:4338856/sequence/default", "files": "https://zenodo.org/api/records/4338856/files", "media_files": "https://zenodo.org/api/records/4338856/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:4338856:Schmalz%20et%20al.%20(2