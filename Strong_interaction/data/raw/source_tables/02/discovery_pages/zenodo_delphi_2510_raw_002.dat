-by-4.0"}, "communities": [{"id": "oliviazwygart"}, {"id": "swissacademies"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "3716975"}}]}, "notes": "Pohl C 2020. Delphi poll. td-net toolbox profile (14). Swiss Academies of Arts and Sciences: \ntd-net toolbox for co-producing knowledge. www.transdisciplinarity.ch/toolbox. doi.org/10.5281/zenodo.3716976"}, "title": "Delphi poll", "links": {"self": "https://zenodo.org/api/records/3716976", "self_html": "https://zenodo.org/records/3716976", "preview_html": "https://zenodo.org/records/3716976?preview=1", "doi": "https://doi.org/10.5281/zenodo.3716976", "self_doi": "https://doi.org/10.5281/zenodo.3716976", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3716976", "reserve_doi": "https://zenodo.org/api/records/3716976/draft/pids/doi", "parent": "https://zenodo.org/api/records/3716975", "parent_html": "https://zenodo.org/records/3716975", "parent_doi": "https://doi.org/10.5281/zenodo.3716975", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.3716975", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:3716976/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:3716976/sequence/default", "files": "https://zenodo.org/api/records/3716976/files", "media_files": "https://zenodo.org/api/records/3716976/media-files", "thumbnails": {"10": "https://zenodo.org/api/iiif/record:3716976:Delphi__td-net_toolbox_profile.pdf/full/%5E10,/0/default.jpg", "50": "https://zenodo.org/api/iiif/record:3716976:Delphi__td-net_toolbox_profile.pdf/full/%5E50,/0/default.jpg", "100": "https://zenodo.org/api/iiif/record:3716976:Delphi__td-net_toolbox_profile.pdf/full/%5E100,/0/default.jpg", "250": "https://zenodo.org/api/iiif/record:3716976:Delphi__td-net_toolbox_profile.pdf/full/%5E250,/0/default.jpg", "750": "https://zenodo.org/api/iiif/record:3716976:Delphi__td-net_toolbox_profile.pdf/full/%5E750,/0/default.jpg", "1200": "https://zenodo.org/api/iiif/record: