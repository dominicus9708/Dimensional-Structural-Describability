://zenodo.org/api/records/7475821/files-archive", "archive_media": "https://zenodo.org/api/records/7475821/media-files-archive", "latest": "https://zenodo.org/api/records/7475821/versions/latest", "latest_html": "https://zenodo.org/records/7475821/latest", "versions": "https://zenodo.org/api/records/7475821/versions", "draft": "https://zenodo.org/api/records/7475821/draft", "access_links": "https://zenodo.org/api/records/7475821/access/links", "access_grants": "https://zenodo.org/api/records/7475821/access/grants", "access_users": "https://zenodo.org/api/records/7475821/access/users", "access_request": "https://zenodo.org/api/records/7475821/access/request", "access": "https://zenodo.org/api/records/7475821/access", "communities": "https://zenodo.org/api/records/7475821/communities", "communities-suggestions": "https://zenodo.org/api/records/7475821/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/7475821/request-deletion", "file_modification": "https://zenodo.org/api/records/7475821/file-modification", "quota_increase": "https://zenodo.org/api/records/7475821/quota-increase", "requests": "https://zenodo.org/api/records/7475821/requests"}, "updated": "2024-07-15T12:31:41.633524+00:00", "recid": "7475821", "revision": 5, "files": [{"id": "675951b3-770e-4658-be74-c5de2d258562", "key": "Tafakkur Manzili-2023-YANVAR-1-qism-93-99.pdf", "size": 444775, "checksum": "md5:9db8cf2481b7a5783b8d641f371923c6", "links": {"self": "https://zenodo.org/api/records/7475821/files/Tafakkur%20Manzili-2023-YANVAR-1-qism-93-99.pdf/content"}}], "swh": null, "owners": [{"id": "265203"}], "status": "published", "stats": {"downloads": 405, "unique_downloads": 326, "views": 584, "unique_views": 519, "version_downloads": 405, "version_unique_downloads": 326, "version_unique_views": 519, "version_views": 584}, "state": "done", "submitted": true}, {"created": "2026-03-29T16:19:50.721133+00:00", "modified": "2026-03-29T16:19:51.025719+00:00", "id": 19318673, "conceptrecid": "19318672", "doi": "10.5281/zenodo.19318673", "conceptdoi": "10.5281/zenodo.19318672", "doi_url": "https://doi.org/10.5281/zenodo.19318673", "metadata": {"title": "RE4GREEN Delphi Round 2: Feedback Report for Participants", "doi": "10.5281/zenodo.19318673", "publication_date": "2026-03-29", "description": "<p><span><em><span lang=\"EN-US\"><span>The Sustainability and Eco-Justice in Everyday Research</span></span></em></span><span lang=\"EN-US\"> competency profile has been developed using a Delphi expert consensus. This report provides the results of the second round of the Delphi for the expert participants.</span></p>\n<p>&nbsp;</p>", "access_right": "open", "creators": [{"name": "Evans, Natalie", "affiliation": "Amsterdam UMC Location VUmc", "orcid": "0000-0001-7124-9282"}], "keywords": ["green transition", "competence profile", "sustainability", "responsible research and innovation"], "resource_type": {"title": "Report", "type": "publication", "subtype": "report"}, "license": {"id": "cc-by-4.0"}, "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "19318672"}}]}}, "title": "RE4GREEN Delphi Round 2: Feedback Report for Participants", "links": {"self": "https://zenodo.org/api/records/19318673", "self_html": "https://zenodo.org/records/19318673", "preview_html": "https://zenodo.org/records/19318673?preview=1", "doi": "https://doi.org/10.5281/zenodo.19318673", "self_doi": "https://doi.org/10.5281/zenodo.19318673", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.19318673", "reserve_doi": "https://zenodo.org/api/records/19318673/draft/pids/doi", "parent": "https://zenodo.org/api/records/19318672", "parent_html": "https://zenodo.org/records/19318672", "parent_doi": "https://doi.org/10.5281/zenodo.19318672", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.19318672", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:19318673/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/recor