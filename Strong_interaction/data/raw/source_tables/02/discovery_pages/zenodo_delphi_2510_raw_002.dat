/records/19318673/file-modification", "quota_increase": "https://zenodo.org/api/records/19318673/quota-increase", "requests": "https://zenodo.org/api/records/19318673/requests"}, "updated": "2026-03-29T16:19:51.025719+00:00", "recid": "19318673", "revision": 4, "files": [{"id": "f5e93798-3023-430d-a621-a8aa95e3d219", "key": "RE4GREEN-Delphi - Feedback Round 2_V2.pdf", "size": 751129, "checksum": "md5:decd1c9e2a349c27e06a75ea6183289f", "links": {"self": "https://zenodo.org/api/records/19318673/files/RE4GREEN-Delphi%20-%20Feedback%20Round%202_V2.pdf/content"}}], "swh": null, "owners": [{"id": "63229"}], "status": "published", "stats": {"downloads": 49, "unique_downloads": 48, "views": 200, "unique_views": 199, "version_downloads": 49, "version_unique_downloads": 48, "version_unique_views": 199, "version_views": 200}, "state": "done", "submitted": true}, {"created": "2020-09-24T18:25:11.543460+00:00", "modified": "2020-09-25T05:31:57.164361+00:00", "id": 4048746, "conceptrecid": "4048745", "doi": "10.5281/zenodo.4048746", "conceptdoi": "10.5281/zenodo.4048745", "doi_url": "https://doi.org/10.5281/zenodo.4048746", "metadata": {"title": "Library Service Platforms (LSPs) characteristics classification via DELPHI method raw data", "doi": "10.5281/zenodo.4048746", "publication_date": "2020-09-24", "description": "<p>The purpose of the research that is related to the dataset&nbsp;is to identify the innovative features of the LSPs (Library Service Platforms)&nbsp;that differentiate them from the LMS (Library Management Systems), as well as to evaluate their importance, based on the opinions of the Greek information scientists. The method used is the Delphi 2-round questionnaire. The dataset contains the results of the Delphi method. Each sheet contains the ranking results from a group of 17 experts from two rounds of the DELPHI method.</p>", "access_right": "open", "creators": [{"name": "Dimitrios Kouis", "affiliation": "Department of Archival, Library & Information Studies, University of West Attica, Athens, Greece", "orcid": "0000-0002-5948-9766"}, {"name": "Georgios Agiorgitis", "affiliation": "Hellenic American Educational Foundation. Athens College - Psychico College, Athens, Greece", "orcid": "0000-0001-9119-491X"}], "keywords": ["Library Management Systems, Library Service Platforms. Delphi method"], "version": "1", "resource_type": {"title": "Dataset", "type": "dataset"}, "license": {"id": "cc-by-4.0"}, "communities": [{"id": "imlr"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "4048745"}}]}}, "title": "Library Service Platforms (LSPs) characteristics classification via DELPHI method raw data", "links": {"self": "https://zenodo.org/api/records/4048746", "self_html": "https://zenodo.org/records/4048746", "preview_html": "https://zenodo.org/records/4048746?preview=1", "doi": "https://doi.org/10.5281/zenodo.4048746", "self_doi": "https://doi.org/10.5281/zenodo.4048746", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.4048746", "reserve_doi": "https://zenodo.org/api/records/4048746/draft/pids/doi", "parent": "https://zenodo.org/api/records/4048745", "parent_html": "https://zenodo.org/records/4048745", "parent_doi": "https://doi.org/10.5281/zenodo.4048745", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.4048745", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:4048746/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:4048746/sequence/default", "files": "https://zenodo.org/api/records/4048746/files", "media_files": "https://zenodo.org/api/records/4048746/media-files", "archive": "https://zenodo.org/api/records/4048746/files-archive", "archive_media": "https://zenodo.org/api/records/4048746/media-files-archive", "latest": "https://zenodo.org/api/records/4048746/versions/latest", "latest_html": "https://zenodo.org/records/4048746/latest", "versions": "https://zenodo.org/api/records/4048746/versions", "draft": "https://zenodo.org/api/records/4048746/draft", "access_links": "https://zenodo.org/api/records/4048746/access/links", "access_grants": "https://zenodo.org/api/records/4048746/access/grants", "access_users": "https://zenodo.org/api/records/4048746/access/users", "access_request": "https://zenodo.org/api/records/4048746/access/request", "access": "https://zenodo.org/api/records/4048746/access", "communities": "https://zenodo.org/api/records/4048746/communities", "communities-suggestions": "https://zenodo.org/api/records/4048746/communities-suggestions", "request_deletion": "https://zenodo.org/api/records/4048746/request-deletion", "file_modification": "https://zenodo.org/api/records/4048746/file-modification", "quota_increase": "https://zenodo.org/api/records/4048746/quota-increase", "requests": "https://zenodo.org/api/records/4048746/requests"}, "updated": "2020-09-25T05:31:57.164361+00:00", "recid": "4048746", "revision": 3, "files": [{"id": "44300343-4304-4fe3-9e7a-800359af99a5", "key": "QuestionnaireRawData.xlsx", "size": 25665, "checksum": "md5:c1bbdab02f40031afad533dacfe1a614", "links": {"self": "https://zenodo.org/api/records/4048746/files/QuestionnaireRawData.xlsx/content"}}], "swh": null, "owners": [{"id": "14078"}], "status": "published", "stats": {"downloads": 47, "unique_downloads": 40, "views": 269, "unique_views": 251, "version_downloads": 47, "version_unique_downloads": 40, "version_unique_views": 249, "version_views": 266}, "state": "done", "submitted": true}, {"created": "2024-03-12T09:50:06.573482+00:00", "modified": "2024-07-06T22:31:57.799916+00:00", "id": 10807834, "conceptrecid": "10807833", "doi": "10.5281/zenodo.10807834", "conceptdoi": "10.5281/zenodo.10807833", "doi_url": "https://doi.org/10.5281/zenodo.10807834", "metadata": {"title": "RRI-LEADERS D3.1 Initial Delphi Questionnaire", "doi": "10.5281/zenodo.10807834", "publication_date": "2021-09-30", "description": "<p><span>This report contains the initial Delphi questionnaires developed for the four territories participating in the&nbsp;RRI-LEADERS Project (municipalities of Sofia and Thalwil, region of Western Macedonia and city of Sabadell). The report</span><span> outlines the various steps that led to the development of the questionnaires, which were used in the three-stage Delphi study conducted in the four territories. The aim of the study was to ensure full integration of stakeholder views and allow validation of RRI principles in practice, while defining the scope of territorial RRI governance and policy implications for the future. </span></p>\n<p><span>For the creation of the first Delphi version, a four-step process was adopted, consisting of the following steps: (i) Best Practice Analysis with Scientific Literature and Practice Literature, (ii) the specification of policy objectives, (iii) qualitative system analysis including the twenty main change factors with respect to the policy focus in each territory, and (iv) the development of a common structure for the Initial Delphi Questionnaires and a first version of the questionnaires in all territories.</span></p>\n<p><span>The report first describes the methodology used to create the questionnaire and then presents the results, i.e., the Initial Delphi Questionnaire for the four territories.</span></p>", "access_right": "open", "creators": [{"name": "Brand, Fridolin", "affiliation": null, "orcid": "0000-0002-2048-3463"}, {"name": "Bl\u00e4se, Richard", "affiliation": null}], "contributors": [{"name": "ZHAW Zurich University of Applied Sciences", "affiliation": null, "type": "WorkPackageLeader"}, {"name": "Applied Research and Communications Fund", "affiliation": null, "type": "ProjectLeader"}, {"name": "University of Western Macedonia", "affiliation": null, "type": "ProjectMember"}, {"name": "Catalan Foundation for Research and Innovation", "affiliation": null, "type": "ProjectMember"}, {"name": "Regional Association of Local Government of Western Macedonia", "affiliation": null, "type": "ProjectMember"}, {"name": "Sofia Development Association", "affiliation": null, "type": "ProjectMember"}, {"name": "Municipality of Thalwil", "affiliation": null, "type": "ProjectMember"}, {"name": "Economic Development Agency of Sabadell City Council", "affiliation": null, "type": "ProjectMember"}], "language": "eng", "custom": {"code:codeRepository": "https://www.rri-leaders.eu/wp-content/uploads/2022/03/D3.1-Initial-Delphi-Questionnaire.pdf"}, "resource_type": {"title": "Project deliverable", "type": "publication", "subtype": "deliverable"}, "license": {"id": "cc-by-4.0"}, "grants": [{"code": "101006439", "internal_id": "10.13039/501100000780::101006439", "funder": {"name": "European Commission", "doi": "10.13039/501100000780", "acronym": "EC"}, "title": "LEVERAGING LEADERSHIP FOR RESPONSIBLE RESEARCH AND INNOVATION IN TERRITORIES", "acronym": "RRI-LEADERS", "program": "H2020-EU.5.c.", "url": "https://cordis.europa.eu/projects/101006439"}], "communities": [{"id": "eu"}], "relations": {"version": [{"index": 0, "is_last": true, "parent": {"pid_type": "recid", "pid_value": "10807833"}}]}}, "title": "RRI-LEADERS D3.1 Initial Delphi Questionnaire", "links": {"self": "https://zenodo.org/api/records/10807834", "self_html": "https://zenodo.org/records/10807834", "preview_html": "https://zenodo.org/records/10807834?preview=1", "doi": "https://doi.org/10.5281/zenodo.10807834", "self_doi": "https://doi.org/10.5281/zenodo.10807834", "self_doi_html": "https://zenodo.org/doi/10.5281/zenodo.10807834", "reserve_doi": "https://zenodo.org/api/records/10807834/draft/pids/doi", "parent": "https://zenodo.org/api/records/10807833", "parent_html": "https://zenodo.org/records/10807833", "parent_doi": "https://doi.org/10.5281/zenodo.10807833", "parent_doi_html": "https://zenodo.org/doi/10.5281/zenodo.10807833", "self_iiif_manifest": "https://zenodo.org/api/iiif/record:10807834/manifest", "self_iiif_sequence": "https://zenodo.org/api/iiif/record:10807834/sequence/default", "files": "https://zenodo.org/api/reco