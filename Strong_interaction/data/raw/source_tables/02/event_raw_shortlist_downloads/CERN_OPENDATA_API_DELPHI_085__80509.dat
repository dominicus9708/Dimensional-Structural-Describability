version_id":"aba9e856-a07c-45f3-94ea-cd1c2578b72d"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:0fd5e6e0","file_id":"82cbf76c-8dc1-4f44-9cec-8e999bc99e3c","key":"DBscon.dat","size":450560,"tags":{},"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBscon.dat","version_id":"08374a60-d071-4533-b3e5-437176ebc8a6"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:1d8e2a3b","file_id":"fb3836f9-36d7-4a0c-b1e0-360b4d970aac","key":"DBsysf.dat","size":131072,"tags":{},"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBsysf.dat","version_id":"9e6b1383-4ec9-4803-b13f-16d7515d27ff"}],"abstract":{"description":"The DELPHI conditions database consists of 7 different files, storing distinct information about the run conditions during the different periods. The format is proprietary, and there are tools available to read it both programmatic from Fortran and interactively, via the commands <i>dplot</i> and applications like <i>dtobin</i> or <i>dlist</i>. The database contains information about the run conditions, including background delivered luminosity, meteorological information, fill information and calibration data for the different detector components.<p>The conditions database is needed for event reconstruction, as provided by the DELPHI event server. It is not needed for data analysis or for simulation. The latter uses yearly snapshot databases instead, which ship with the corresponding simulation version.<p> Manuals, including usage examples, are available from the CERN document server, in particular the <a href='https://cds.cern.ch/record/2625473/files/delphi-93-5_ocr.pdf'>CARGO Database Management Package</a>, the <a href='https://cds.cern.ch/record/2630031/files/96_139_das_180_prog_219.pdf'>DPLOT Database graphics</a> and the <a href='https://cds.cern.ch/record/2629009/files/delphi-90-37_ocr.pdf'>DELPHI Detector Description Application Package user manual</a>."},"accelerator":"CERN-LEP","availability":"online","collaboration":{"name":"DELPHI collaboration","recid":"80050"},"collections":["DELPHI-Condition-Data"],"date_created":["2000"],"date_published":"2025","distribution":{"formats":["dat"],"number_files":7,"size":3205865472},"doi":"10.7483/OPENDATA.DELPHI.18JY.GL8K","experiment":["DELPHI"],"files":[{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:18ab9196","key":"DBcalb.dat","size":1497251840,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBcalb.dat","version_id":"043d0227-8d54-4c7a-b5db-e695c4859c03"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:b74dd263","key":"DBgeom.dat","size":32432128,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBgeom.dat","version_id":"5e67924f-112e-4e80-914b-a7a0c5c29294"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:21bf3c40","key":"DBlepm.dat","size":1655250944,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBlepm.dat","version_id":"0e88b88c-b910-4799-84d6-77ca034bdf63"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:dc088849","key":"DBmisc.dat","size":40960,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBmisc.dat","version_id":"48fa3b2a-3065-43d0-b4d1-d167723f3a8e"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:0190cfad","key":"DBrunt.dat","size":20307968,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBrunt.dat","version_id":"aba9e856-a07c-45f3-94ea-cd1c2578b72d"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:0fd5e6e0","key":"DBscon.dat","size":450560,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBscon.dat","version_id":"08374a60-d071-4533-b3e5-437176ebc8a6"},{"availability":"online","bucket":"e398a139-5c13-4145-afa1-b50846654932","checksum":"adler32:1d8e2a3b","key":"DBsysf.dat","size":131072,"uri":"root://eospublic.cern.ch//eos/opendata/delphi/condition-data/DBsysf.dat","version_id":"9e6b1383-4ec9-4803-b13f-16d7515d27ff"}],"license":{"attribution":"CC0-1.0"},"pids":{"oai":{"id":"oai:cernopendata.cern:80509"}},"publisher":"CERN Open Data Portal","recid":"80509","title":"DELPHI conditions databases","type":{"primary":"Environment","secondary":["Condition"]}},"updated":"2025-12-12T14:59:01.520784+00:00"}